# Production template. Do not commit real secrets.

ND_APP_NAME=NigehbaanDastak
ND_APP_VERSION=0.1.0
ND_ENVIRONMENT=production
ND_DEBUG=false
ND_LOG_LEVEL=INFO
ND_RATE_LIMIT_ENABLED=true
ND_RATE_LIMIT_WINDOW_SECONDS=60
ND_RATE_LIMIT_MAX_WRITE_REQUESTS=120
ND_DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<dbname>
ND_CORS_ORIGINS=["https://<your-frontend-domain>"]
